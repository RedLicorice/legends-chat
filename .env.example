# Postgres
DATABASE_URL=postgres://legends:legends@localhost:5432/legends

# Redis
REDIS_URL=redis://localhost:6379

# JWT signing keys (generate strong random values for prod)
JWT_ACCESS_SECRET=dev-access-secret-change-me-please-32bytes-min
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-please-32bytes-min
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# Server-side at-rest encryption master key (32 bytes, base64)
# generate with: openssl rand -base64 32
ENCRYPTION_MASTER_KEY=ZGV2LW1hc3Rlci1rZXktY2hhbmdlLW1lLXBsZWFzZS0zMmJ5dGVzCg==

# Web Push (VAPID) - generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Telegram bot
TELEGRAM_BOT_TOKEN=
APP_PUBLIC_URL=http://localhost:3000

# Service URLs
WEB_URL=http://localhost:3000
WS_URL=http://localhost:3001
WS_PORT=3001
NEXT_PUBLIC_WS_URL=http://localhost:3001
